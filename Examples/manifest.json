

// Manifest is managed by Service Worker and BACKEND server !!!

// FOR mainifest.json COMMENTS MUST BE DELETED !!!

// Mechanism of applying new manifest:
// https://web.dev/manifest-updates/

{
  "lang": "en-US",
  // "name" or "short_name" REQUIRED
  // PWA app / shortcut title
  "short_name": "Kupidon",
  // As html title
  "name": "Kupidon - date app",
  // As html meta description
  "description": "Kupidon is a dating and relationship app. We offer users a selection of date ideas and places to make their meetings unforgettable.",
  // REQUIRED
  "start_url": ".",
  // REQUIRED
  // 'fullscreen' | 'standalone' | 'minimal-ui'
  "display": "standalone",
  // Orientation when installed as PWA
  "orientation": "portrait",
  
  
  // Splashscreen colors can't be overriden by html <meta/>
  // When app has loaded, html <meta/> will override manifest values.
  
  // На нижний бар с полоской навигации андроида эти настройки не влияют
  
  // Splashscreen status bar color.
  // Title bar of window, status bar on mobile.
  // It will be overriden by <meta name="theme-color" .../>.
  "theme_color": "#282c34",
  
  // Splashscreen bg color.
  // NOT Window or Viewport bg
  "background_color": "#282c34",
  
  // body background is WINDOW background
  
  
  /*
    Favicon - Иконка PWA на Android / PC + used in browser tab
    Define in index.html:
    There is png because iOS does not support svg
    <link rel="icon" type="image/png" href="%BASE_URL%public/assets/icon64.png"/>
    <link rel="icon" type="image/svg+xml" href="%BASE_URL%public/assets/icon.svg"/>
    NO PADDINGS
    
    Также используется для обычного ярлыка сайта Android - там уже НУЖНЫ ПАДДИНГИ, но пофиг
  */
  /*
    Apple touch icon - Иконка PWA на iOS
    Define in index.html:
    <link rel="apple-touch-icon" type="image/png" href="%BASE_URL%public/assets/icon192-padding.png"/>
    WITH PADDINGS
  */
  // paths are relative because manifest.json in root
  "icons": [
    // REQUIRED size, NO PADDINGS
    {
      "src": "public/assets/icon192.png",
      "type": "image/png",
      "sizes": "192x192"
    },
    // REQUIRED size, NO PADDINGS
    // Android splashscreen icon
    {
      "src": "public/assets/icon512.png",
      "type": "image/png",
      "sizes": "512x512"
    },
    // MASKABLE WITH PADDINGS
    // Android PWA shortcut icon
    /*{
      "src": "public/assets/icon512-padding.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }*/
  ],
  /*
    Need to include all icons in vite.config.ts pwaOptions:
    includeAssets: ['public/*'],
  */
  
  // REQUIRED: prefer_related_applications не должен присутствовать или должен быть false
  // Note: На Android, если манифест веб-приложения включает
  // related_applications и "prefer_related_applications": true,
  // пользователь будет перенаправлен в магазин Google Play и
  // вместо этого ему будет предложено установить указанное приложение Android.
}